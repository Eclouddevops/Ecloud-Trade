# API Keys (optional - for premium data sources)
BREEZE_API_KEY=your_breeze_api_key
BREEZE_SECRET=your_breeze_secret
TRUEDATA_USER=your_truedata_username
TRUEDATA_PASSWORD=your_truedata_password

# ─── Broker APIs (for REAL-TIME data - configure one) ──────────────────────────

# Zerodha Kite (pip install kiteconnect)
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_ACCESS_TOKEN=

# Angel One SmartAPI (pip install smartapi-python pyotp)
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_PASSWORD=
ANGEL_TOTP_SECRET=

# Dhan (pip install dhanhq)
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# Flask Config
FLASK_SECRET_KEY=your_secret_key
FLASK_DEBUG=True
FLASK_PORT=5000

# ─── Google OAuth (for login) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
ALLOWED_EMAILS=your@gmail.com,another@gmail.com
